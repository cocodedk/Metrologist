# Normalize line endings
* text=auto eol=lf

# Source code
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.py        text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.go        text eol=lf
*.sh        text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.toml      text eol=lf
*.properties text eol=lf

